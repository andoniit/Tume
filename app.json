{
  "expo": {
    "name": "Tume",
    "slug": "Tume",
    "scheme": "tume",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.andonkap.Tume",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "Tume needs access to your photo library to upload a profile picture.",
        "NSPhotoLibraryAddUsageDescription": "Tume saves your selected profile photo.",
        "NSCameraUsageDescription": "Tume uses the camera only if you choose to take a new profile photo."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.andonkap.Tume"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-web-browser",
      "@react-native-community/datetimepicker",
      "expo-router"
    ],
    "extra": {
      "eas": {
        "projectId": "69b41890-e1eb-46e0-ae57-a6df91dcd984"
      }
    }
  }
}
